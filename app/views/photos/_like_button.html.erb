<% liked = @liked_photo_ids.include?(photo.id) %>
<% like = photo.likes.find { |like| like.user_id == current_user.id } %>

<%= turbo_frame_tag dom_id(photo, :like), class: "flex flex-col items-center w-1/3 md:flex-row md:w-full md:justify-between lg:flex-col lg:w-1/3 lg:justify-normal" do %>
  <% if liked %>
    <%= button_to like_path(like),
      class: 'like-button',
      method: :delete,
      data: {
        controller: "like",
        action: "click->like#toggle" } do %>
      <%= image_tag(
        "star-fill.svg",
        class: "w-6 star-fill",
        data: {
          like_target: "fill",
        },
      ) %>
      <%= image_tag(
        "star-line.svg",
        class: "w-6 star-line hidden",
        data: {
          like_target: "line",
        },
      ) %>
    <% end %>
  <% else %>
    <%= button_to likes_path(photo_id: photo.id),
      class: 'like-button',
      data: {
        controller: "like",
        action: "click->like#toggle" } do %>
      <%= image_tag(
        "star-line.svg",
        class: "w-6 star-line",
        data: {
          like_target: "line",
        },
      ) %>
      <%= image_tag(
        "star-fill.svg",
        class: "w-6 star-line hidden",
        data: {
          like_target: "fill",
        },
      ) %>
    <% end %>
  <% end %>
  <span class='text-sm'>
    Likes:
    <%= photo.likes.size %>
  </span>
<% end %>
