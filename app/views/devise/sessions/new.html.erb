<div class="min-h-screen flex flex-col items-center justify-center bg-gray-50">
  <div class="pb-4 flex items-center">
    <%= image_tag "logo.svg", alt: "Clever Logo", class: "w-12" %>
    <span class='text-xl text-clever-blue ml-2 font-extrabold'>CleverPhotoGallery</span>
  </div>
  <div class="flex flex-col items-center bg-white p-6 rounded-lg shadow gap-4">
    <h2 class='text-2xl font-bold'>Welcome back</h2>
    <p class='text-gray-500'>Sign in to continue to your gallery</p>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="field my-4">
        <p><%= f.label :email, class: "font-bold" %></p>
        <p><%= f.email_field :email,
                        autofocus: true,
                        autocomplete: "email",
                        placeholder: "demo@example.com",
                        class: "border border-solid border-gray-200 rounded-lg p-2" %></p>
      </div>

      <div class="field mb-4">
        <p><%= f.label :password, class: "font-bold" %></p>
        <p><%= f.password_field :password,
                           autocomplete: "current-password",
                           placeholder: "••••••••",
                           class: "border border-solid border-gray-200 rounded-lg p-2" %></p>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="field">
          <p><%= f.check_box :remember_me %></p>
          <p><%= f.label :remember_me %></p>
        </div>
      <% end %>

      <div class="actions w-full flex justify-center">
        <%= f.submit "Sign in", class: "bg-clever-blue w-full rounded-lg text-white py-2" %>
      </div>
    <% end %>

  </div>
</div>
